# =============================================================================
# LiteLLM config.yaml — 設定檔範本
# =============================================================================
# 用途：複製此檔為 config.yaml（與 compose.yaml 同目錄）
# 所有 secrets 一律使用 os.environ/... 引用，絕對不可寫死
# =============================================================================

# ---------------------------------------------------------------------------
# 模型清單 — model_list
# ---------------------------------------------------------------------------
#
# ⚠️ UI/DB-first 模式：model_list 保持為空，模型與 provider credentials
#    統一透過 Admin UI / API 管理（store_model_in_db: true）。
#    靜態註冊模型已廢除，請勿在此檔案填寫 provider API key。
# ---------------------------------------------------------------------------
# Phase 3 前置配置調整（2026-06-24）：不再於 static config 預先註冊 provider models。
# 統一透過 Admin UI / API 建立 LLM Credentials 與 DB-managed models。
# 詳細說明：LiteLLM 支援將模型設定存入 PostgreSQL（store_model_in_db: true），
# 可透過 Admin UI 或 API 動態管理 provider credentials，
# 避免 provider key rotation 需要重建 container。
model_list: []

# ---------------------------------------------------------------------------
# LiteLLM 全域設定 — litellm_settings
# ---------------------------------------------------------------------------
litellm_settings:
  # === Observability — 啟用 Prometheus metrics ===
  # 啟用後可 GET /metrics 供 Prometheus scrape
  # 注意：LiteLLM 1.89.0 需同時設定 success_callback 才能正確掛載 /metrics
  callbacks: ["prometheus"]
  success_callback: ["prometheus"]

  # === Redis — 多 pod 部署必備，單機 PoC 亦啟用以驗證整合 ===
  # LiteLLM 會將 health check 結果寫入 Redis，各 pod 共用
  # 避免多 pod 重複打 provider 造成 RPM 消耗
  # 對應 compose.yaml 中 REDIS_HOST / REDIS_PORT / REDIS_PASSWORD env
  redis_host: os.environ/REDIS_HOST
  redis_port: os.environ/REDIS_PORT
  redis_password: os.environ/REDIS_PASSWORD

  # === Cache — 啟用 LiteLLM Redis cache，供 RPM/TPM/runtime counters 跨 instance 使用 ===
  # 注意：設定 redis_host/redis_port 只是連線參數；
  # 必須同時啟用 cache: true + cache_params.type: redis 才會初始化 LiteLLM RedisCache，
  # 讓子服務（RPM limiter、usage cache）可寫入 Redis。
  # cache_params 必須明確指定 host/port/password，否則 LiteLLM 不會自動使用
  # litellm_settings.redis_host 等值（LiteLLM 只在 cache_params 完全空白時才 fallback）。
  cache: true
  cache_params:
    type: redis
    host: os.environ/REDIS_HOST
    port: os.environ/REDIS_PORT
    password: os.environ/REDIS_PASSWORD

  # === 上游 provider 全域設定 ===
  # 忽略 provider 不支援的參數，避免 SDK 報錯
  drop_params: true

  # 詳細日誌（生產建議 false）
  # set_verbose: false

  # JSON 格式日誌（方便 APM 解析，生產建議 true）
  # json_logs: true

  # === 失敗重試設定（可選）===
  # num_retries: 3
  # timeout: 60

# ---------------------------------------------------------------------------
# 一般設定 — general_settings
# ---------------------------------------------------------------------------
general_settings:
  # === Core（必填）===
  # 管理員金鑰 — Admin API 唯一認證，勿給客戶端使用
  master_key: os.environ/LITELLM_MASTER_KEY

  # PostgreSQL 連線字串
  # 必填：virtual keys、Admin UI、spend tracking、模型設定儲存
  database_url: os.environ/DATABASE_URL

  # 將模型設定存入 DB，支援 Admin UI 管理模型（建議 true）
  store_model_in_db: true

  # === Admin UI ===
  # 啟用 Admin UI（http://host:4000）
  admin_ui: true

  # === Security（可選）===
  # 不儲存完整 response（隱私敏感時建議 true）
  # store_completion: false
  # store_model_plus_response: false

  # === User-level RPM（Phase 1 PoC / 建議正式環境啟用）===
  # 強制要求 request body 包含 `user` 參數，未帶 user 的請求會被拒絕
  # 啟用後可搭配 /customer/new + /budget/new 實作 user-level RPM limit
  # 詳細說明：https://docs.litellm.ai/docs/proxy/user_param
  enforce_user_param: true

  # === CORS（跨域需求時啟用）===
  # cors_origin: "*"
  # cors_allow_credentials: true

  # === 多組織/多租戶（可選）===
  # store_team_in_db: true
  # default_team_id: "default-team"

# ---------------------------------------------------------------------------
# 透過 Admin UI 新增 Gemini 模型（不要寫入此檔案）
# ---------------------------------------------------------------------------
# 热门 Google AI Studio 公共模型（直接使用 Gemini API，無需 Vertex）：
#   model_name: gemini-2.5-flash-lite   → litellm_params.model: gemini/gemini-2.5-flash-lite
#   model_name: gemini-2.5-flash        → litellm_params.model: gemini/gemini-2.5-flash
#   model_name: gemini-2.5-pro          → litellm_params.model: gemini/gemini-2.5-pro
#
# 操作方式（任選一）：
#   1. Admin UI：http://localhost:4000 → Models → Add Your First Model
#   2. API：POST /model/new（需附上 LITELLM_MASTER_KEY）
#
# Vertex AI（若使用 Google Cloud Vertex AI）：
#   請在 Admin UI 建立 Vertex AI credential，
#   範例 model_name: vertex-gemini-2.5-flash → litellm_params.model: vertex_ai/gemini-2.5-flash
# ---------------------------------------------------------------------------
