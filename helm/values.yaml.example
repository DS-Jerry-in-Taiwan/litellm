# =============================================================================
# LiteLLM Helm Values 範本 — Kubernetes / Helm 部署
# =============================================================================
# 用途：複製為 values.yaml，配合官方 LiteLLM Helm Chart 使用
# Helm repo：https://github.com/BerriAI/litellm-helm
#   helm repo add berriai https://berriai.github.io/litellm-helm
#   helm repo update
#   helm install litellm berriai/litellm --namespace litellm --values values.yaml
#
# 重要：所有 secrets 必須透過 secretKeyRef 引用 K8s Secret，絕對不可寫入 values.yaml
# =============================================================================

# ---------------------------------------------------------------------------
# 副本數
# ---------------------------------------------------------------------------
replicaCount: 2

# ---------------------------------------------------------------------------
# 映像檔
# ---------------------------------------------------------------------------
image:
  repository: docker.litellm.ai/berriai/litellm
  # 生產建議固定版本 tag，避免 image 拉取不一致
  tag: "main-stable"
  pullPolicy: IfNotPresent

# ---------------------------------------------------------------------------
# Service
# ---------------------------------------------------------------------------
service:
  type: ClusterIP      # 生產建議 ClusterIP；Local 可用 NodePort / LoadBalancer
  port: 4000
  annotations: {}

# ---------------------------------------------------------------------------
# Ingress（Production 必備 TLS）
# ---------------------------------------------------------------------------
ingress:
  enabled: true
  className: nginx
  annotations:
    # TLS 終止建議使用 cert-manager + Let's Encrypt
    cert-manager.io/cluster-issuer: letsencrypt-prod
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    # 可選：限制連線來源
    # kubernetes.io/ingress.class: nginx
  hosts:
    - host: litellm.internal.example.com
      paths:
        - path: /
          pathType: Prefix
  tls:
    - secretName: litellm-tls-secret
      hosts:
        - litellm.internal.example.com

# ---------------------------------------------------------------------------
# 資源限制（建議設定，避免 OOM 被 kill）
# ---------------------------------------------------------------------------
resources:
  requests:
    cpu: 500m
    memory: 512Mi
  limits:
    cpu: 2000m
    memory: 2Gi

# ---------------------------------------------------------------------------
# 健康檢查（Startup / Liveness / Readiness）
# ---------------------------------------------------------------------------
livenessProbe:
  httpGet:
    path: /health
    port: 4000
  initialDelaySeconds: 30
  periodSeconds: 10
  timeoutSeconds: 5
  failureThreshold: 3

readinessProbe:
  httpGet:
    path: /health
    port: 4000
  initialDelaySeconds: 10
  periodSeconds: 5
  timeoutSeconds: 3
  failureThreshold: 3

startupProbe:
  httpGet:
    path: /health
    port: 4000
  initialDelaySeconds: 60
  periodSeconds: 10
  timeoutSeconds: 5
  failureThreshold: 6

# ---------------------------------------------------------------------------
# Autoscaling（HPA — 依 CPU / Memory）
# ---------------------------------------------------------------------------
autoscaling:
  enabled: true
  minReplicas: 2
  maxReplicas: 10
  targetCPUUtilizationPercentage: 70
  targetMemoryUtilizationPercentage: 80
  # 可選：自訂指標（需 Prometheus Adapter）
  # metrics:
  #   - type: Resource
  #     resource:
  #       name: cpu
  #       target:
  #         type: Utilization
  #         averageUtilization: 70

# ---------------------------------------------------------------------------
# Pod Disruption Budget（確保滾動更新時至少有一個 pod 可用）
# ---------------------------------------------------------------------------
podDisruptionBudget:
  enabled: true
  minAvailable: 1
  # maxUnavailable: 1  # 與 minAvailable 二選一

# ---------------------------------------------------------------------------
# Pod Annotations（可加監控 label）
# ---------------------------------------------------------------------------
podAnnotations:
  prometheus.io/scrape: "true"
  prometheus.io/port: "4000"
  prometheus.io/path: "/metrics"

# ---------------------------------------------------------------------------
# 節點親和性（可選，生產建議指定節點）
# ---------------------------------------------------------------------------
# nodeAffinity:
#   requiredDuringSchedulingIgnoredDuringExecution:
#     nodeSelectorTerms:
#       - matchExpressions:
#           - key: node-type
#             operator: In
#             values:
#               - litellm-workers

# ---------------------------------------------------------------------------
# 容忍（Taints / Tolerations）
# ---------------------------------------------------------------------------
# tolerations:
#   - key: "node-type"
#     operator: "Equal"
#     value: "litellm-workers"
#     effect: "NoSchedule"

# ---------------------------------------------------------------------------
# 資料持久化（若使用本地 Postgres，非 managed DB）
# ---------------------------------------------------------------------------
persistence:
  enabled: true
  size: 10Gi
  storageClass: standard   # 依 K8s 環境調整
  accessMode: ReadWriteOnce

# ---------------------------------------------------------------------------
# ConfigMap — 存放 config.yaml（不含 secrets）
# ---------------------------------------------------------------------------
config:
  # 完整 config.yaml 內容（所有 secrets 使用 os.environ/...）
  model_list:
    - model_name: gpt-4o-mini
      litellm_params:
        model: openai/gpt-4o-mini
        api_key: os.environ/OPENAI_API_KEY
    # 新增更多模型...

  litellm_settings:
    callbacks:
      - prometheus
    # redis_host: os.environ/REDIS_HOST
    # redis_port: os.environ/REDIS_PORT
    drop_params: true
    # json_logs: true

  general_settings:
    master_key: os.environ/LITELLM_MASTER_KEY
    database_url: os.environ/DATABASE_URL
    store_model_in_db: true
    admin_ui: true
    # cors_origin: "*"

# ---------------------------------------------------------------------------
# Secrets — 所有機密資料（由 K8s Secret / Secret Manager 注入）
# ---------------------------------------------------------------------------
# 重要：這些值應來自於預先建立的 K8s Secret，絕對不要把真實 key 寫在 values.yaml
# 建立方式：
#   kubectl create secret generic litellm-secrets \
#     --namespace litellm \
#     --from-literal=LITELLM_MASTER_KEY=sk-your-master-key \
#     --from-literal=LITELLM_SALT_KEY=your-salt-key \
#     --from-literal=DATABASE_URL=postgresql://user:pass@host:5432/litellm \
#     --from-literal=OPENAI_API_KEY=sk-your-openai-key
# ---------------------------------------------------------------------------
secret:
  # LITELLM_MASTER_KEY: "sk-placeholder-replace-before-use"
  # LITELLM_SALT_KEY: "placeholder-salt-key-min-32-chars"
  # DATABASE_URL: "postgresql://litellm:password@postgres-svc:5432/litellm"
  # OPENAI_API_KEY: "sk-placeholder"
  # REDIS_HOST: "redis-service"
  # REDIS_PORT: "6379"

# ---------------------------------------------------------------------------
# 環境變數（envFrom — 從 Secret 注入）
# ---------------------------------------------------------------------------
# 使用 secretKeyRef 從已建立的 K8s Secret 注入環境變數
envFrom:
  - secretRef:
      name: litellm-secrets        # 替換為你的 Secret 名稱
  # - configMapRef:
  #     name: litellm-configmap     # 可選：額外 ConfigMap

# ---------------------------------------------------------------------------
# 額外環境變數（非 secrets，可放 ConfigMap）
# ---------------------------------------------------------------------------
extraEnv:
  # PostgreSQL（可選，明碼使用 envFrom Secret 中的 DATABASE_URL 即可）
  # POSTGRES_DB: "litellm"
  # Litellm 設定（這些也可以放在 config.yaml）
  # LITELLM_LOG_LEVEL: "INFO"

# ---------------------------------------------------------------------------
# Postgres External（Managed DB 建議使用 external 方式引用）
# ---------------------------------------------------------------------------
# externalDatabase:
#   enabled: true
#   host: "your-managed-postgres.example.com"
#   port: 5432
#   database: "litellm"
#   username: "litellm"
#   # 密碼應透過 existingSecret 引用
#   existingSecret: "litellm-db-secret"
#   secretKeys:
#     password: "POSTGRES_PASSWORD"

# ---------------------------------------------------------------------------
# Redis External（可選，若使用 managed Redis）
# ---------------------------------------------------------------------------
# externalRedis:
#   enabled: true
#   host: "your-managed-redis.example.com"
#   port: 6379
#   existingSecret: "litellm-redis-secret"
#   secretKeys:
#     password: "REDIS_PASSWORD"

# ---------------------------------------------------------------------------
# 共享健康檢查（多 pod 部署強烈建議啟用 Redis）
# ---------------------------------------------------------------------------
# 多 pod 時未啟用 Redis 會導致每個 pod 各自打 provider health check，
# 造成 RPM/Rate limit 消耗為 N × pod_count

# ---------------------------------------------------------------------------
# Pod Anti-Affinity（建議分散到不同節點）
# ---------------------------------------------------------------------------
# podAntiAffinity:
#   preferredDuringSchedulingIgnoredDuringExecution:
#     - weight: 100
#       podAffinityTerm:
#         labelSelector:
#           matchExpressions:
#             - key: app
#               operator: In
#               values:
#                 - litellm
#         topologyKey: kubernetes.io/hostname

# ---------------------------------------------------------------------------
# Security Context（Pod 層級）
# ---------------------------------------------------------------------------
# securityContext:
#   runAsNonRoot: true
#   runAsUser: 1000
#   fsGroup: 1000

# ---------------------------------------------------------------------------
# Container Security Context（Container 層級）
# ---------------------------------------------------------------------------
# containerSecurityContext:
#   readOnlyRootFilesystem: true
#   capabilities:
#     drop:
#       - ALL
