# =============================================================================
# LiteLLM .env.example — 環境變數範本
# =============================================================================
# 用途：複製此檔為 .env 並填入真實值（.env 不可進 Git）
# 警告：LITELLM_MASTER_KEY 建議 ≥32 字元隨機字串，生產環境務必替換
# =============================================================================

# === LiteLLM Core Secrets（必填） ===

# 管理員金鑰 — 用於 Admin API 認證，勿給客戶端使用
# 建議：openssl rand -hex 32
LITELLM_MASTER_KEY=sk-change-me-replace-before-use

# DB 敏感欄位加密鹽 — 建議：openssl rand -hex 32
LITELLM_SALT_KEY=replace-with-random-32-byte-secret

# === PostgreSQL Database ===

DATABASE_URL=postgresql://litellm:litellm_password_change_me@postgres:5432/litellm
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm_password_change_me

# === LLM Provider API Keys ===

# OpenAI（必填至少一項）
OPENAI_API_KEY=replace-with-provider-key

# Anthropic（可選）
# ANTHROPIC_API_KEY=replace-with-anthropic-key

# Azure OpenAI（可選）
# AZURE_API_KEY=replace-with-azure-key
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-06-01

# === Redis（多 pod 部署建議啟用，單機 PoC 可省略） ===

REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=replace-with-redis-password

# === LiteLLM General Settings ===

# 啟用 DB 儲存 model 設定（允許 Admin UI 動態新增 model）
# 僅在 config.yaml 設定 general_settings.store_model_in_db: true 不足，需同時設定此 env
STORE_MODEL_IN_DB=True

# === 可選：Admin UI 基本認證 ===
# UI_USERNAME=admin
# UI_PASSWORD=replace-with-admin-ui-password

# === 可選：SMTP（寄送用量通知等） ===
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
